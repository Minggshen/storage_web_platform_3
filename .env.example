# 后端服务环境变量
# 复制为 .env 后使用

# CORS 允许的来源（逗号分隔）
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# OpenDSS 相关（求解器引擎）
STORAGE_OPENDSSCONSTRAINTORACLE_ENABLED=false
STORAGE_DSS_MASTER_PATH=
STORAGE_OPENDSS_TARGET_BUS=
STORAGE_OPENDSS_VOLTAGE_LIMIT_PU=1.05
